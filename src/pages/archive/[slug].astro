---
// src/pages/archive/[slug].astro
import Layout from "../../layouts/Layout.astro";
import { prisma } from "../../lib/prisma";

export async function getStaticPaths() {
  const artifacts = await prisma.artifact.findMany({
    select: { slug: true },
  });

  return artifacts.map((artifact) => ({
    params: { slug: artifact.slug },
  }));
}

const { slug } = Astro.params;

const artifact = await prisma.artifact.findUnique({
  where: { slug },
  include: {
    creator: true,
    collection: true,
    materials: {
      include: { material: true },
    },
    images: {
      orderBy: { sortOrder: "asc" },
    },
    events: {
      orderBy: { occurredAt: "asc" },
    },
    ownerships: {
      include: { owner: true },
      orderBy: { acquiredAt: "asc" },
    },
    certificate: true,
  },
});

if (!artifact) {
  return Astro.redirect("/404");
}

const primaryImage =
  artifact.images.find((image) => image.isPrimary) ?? artifact.images[0];

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
---

<Layout title={`${artifact.title} | Archive`}>
  <main class="archive-page">
    <section class="hero">
      {primaryImage && (
        <img
          src={primaryImage.url}
          alt={primaryImage.altText ?? artifact.title}
          class="hero-image"
        />
      )}

      <div class="hero-copy">
        <p class="eyebrow">
          {artifact.collection?.title ?? "Archive Artifact"}
        </p>

        <h1>{artifact.title}</h1>

        {artifact.editionNo && (
          <p class="edition">Edition {artifact.editionNo}</p>
        )}

        {artifact.description && (
          <p class="description">{artifact.description}</p>
        )}

        <div class="meta">
          <p><strong>Creator:</strong> {artifact.creator.name}</p>
          <p><strong>Status:</strong> {artifact.status}</p>

          {artifact.priceCents && (
            <p>
              <strong>Price:</strong>{" "}
              {(artifact.priceCents / 100).toLocaleString("en-US", {
                style: "currency",
                currency: artifact.currency ?? "USD",
              })}
            </p>
          )}
        </div>
      </div>
    </section>

    <section>
      <h2>Materials</h2>

      <ul class="pill-list">
        {artifact.materials.map(({ material }) => (
          <li>{material.name}</li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Provenance</h2>

      <ol class="timeline">
        {artifact.events.map((event) => (
          <li>
            <time>{formatDate(event.occurredAt)}</time>
            <h3>{event.title}</h3>
            <p>{event.type}</p>

            {event.notes && <p>{event.notes}</p>}
            {event.location && <p>Location: {event.location}</p>}
            {event.actorName && <p>Actor: {event.actorName}</p>}
          </li>
        ))}
      </ol>
    </section>

    {artifact.ownerships.length > 0 && (
      <section>
        <h2>Ownership History</h2>

        <ol class="timeline">
          {artifact.ownerships.map((record) => (
            <li>
              <time>{formatDate(record.acquiredAt)}</time>
              <h3>{record.owner.name ?? "Private Collector"}</h3>

              {record.acquisitionMethod && (
                <p>{record.acquisitionMethod}</p>
              )}

              {record.notes && <p>{record.notes}</p>}
            </li>
          ))}
        </ol>
      </section>
    )}

    {artifact.certificate && (
      <section class="certificate">
        <h2>Certificate</h2>
        <p><strong>Code:</strong> {artifact.certificate.publicCode}</p>
        <p><strong>Issued:</strong> {formatDate(artifact.certificate.issuedAt)}</p>

        {artifact.certificate.statement && (
          <p>{artifact.certificate.statement}</p>
        )}
      </section>
    )}
  </main>
</Layout>

<style>
  .archive-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  .hero-image {
    width: 100%;
    border-radius: 1rem;
    object-fit: cover;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 5rem);
    line-height: 0.95;
    margin: 0.5rem 0 1rem;
  }

  .edition {
    font-style: italic;
    opacity: 0.75;
  }

  .description {
    font-size: 1.15rem;
    line-height: 1.6;
  }

  section {
    margin-bottom: 3rem;
  }

  .pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    list-style: none;
  }

  .pill-list li {
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
  }

  .timeline {
    list-style: none;
    padding: 0;
    border-left: 1px solid currentColor;
  }

  .timeline li {
    padding: 0 0 2rem 1.5rem;
  }

  .timeline time {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .timeline h3 {
    margin: 0.25rem 0;
  }

  .certificate {
    border: 1px solid currentColor;
    padding: 2rem;
    border-radius: 1rem;
  }

  @media (max-width: 800px) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
